{
  "name": "@miradorlabs/nodejs-sdk",
  "version": "2.4.0",
  "packageManager": "pnpm@10.33.0",
  "description": "Node.js SDK for Mirador — cross-chain observability for blockchain applications.",
  "homepage": "https://mirador.org",
  "repository": {
    "type": "git",
    "url": "https://github.com/miradorlabs/nodejs-sdk"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "prepare": "husky",
    "prepublishOnly": "npm run build",
    "build": "rm -rf dist/ && rollup -c",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "cli": "tsx ./example/cli.ts",
    "release:patch": "npm version patch && git push --follow-tags",
    "release:minor": "npm version minor && git push --follow-tags",
    "release:major": "npm version major && git push --follow-tags"
  },
  "keywords": [
    "mirador",
    "ingest",
    "sdk",
    "typescript",
    "grpc",
    "tracing"
  ],
  "author": "@mirador",
  "license": "MIT",
  "devDependencies": {
    "@commitlint/cli": "^20.4.1",
    "@commitlint/config-conventional": "^20.4.1",
    "@eslint/js": "^9.39.1",
    "@rollup/plugin-commonjs": "^29.0.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.10.1",
    "dotenv": "^17.2.3",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "jiti": "^2.6.1",
    "prettier": "^3.6.2",
    "rollup": "^4.53.3",
    "rollup-plugin-dts": "^6.2.3",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "ts-proto": "^2.8.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.47.0"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.10.1",
    "@grpc/grpc-js": "^1.14.1",
    "@miradorlabs/ingest-grpc": "1.1.0",
    "@miradorlabs/plugins": "1.3.0",
    "google-protobuf": "^4.0.1",
    "rxjs": "^7.8.2"
  },
  "pnpm": {
    "overrides": {
      "js-yaml": "^4.2.0"
    },
    "onlyBuiltDependencies": [
      "esbuild"
    ],
    "ignoredBuiltDependencies": [
      "protobufjs",
      "unrs-resolver"
    ]
  }
}
